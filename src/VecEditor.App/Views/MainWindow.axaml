<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VecEditor.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:VecEditor.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="VecEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="VecEditor">

	<Grid RowDefinitions="Auto,Auto,*">

		<!-- СТРОКА МЕНЮ (первая строка) -->
		<Menu Grid.Row="0" Margin="5">
			<MenuItem Header="_File">
				<MenuItem Header="_New"/>
				<MenuItem Header="_Open"/>
				<MenuItem Header="_Save"/>
				<Separator/>
				<MenuItem Header="E_xit"/>
			</MenuItem>
			<MenuItem Header="_Edit">
				<MenuItem Header="_Undo"/>
				<MenuItem Header="_Redo"/>
			</MenuItem>
			<MenuItem Header="_View">
				<MenuItem Header="Zoom In"/>
				<MenuItem Header="Zoom Out"/>
			</MenuItem>
		</Menu>


		<!-- ПАНЕЛЬ ИНСТРУМЕНТОВ (вторая строка) -->
		<Grid Grid.Row="1" Margin="5" Height="80">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="2*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- Колонка 1: Карандашные инструменты -->
			<Border Grid.Column="0" BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2"
                    Padding="5"
					Background="Gray">
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">

					<!--// Mode=OneWay
					// Посмотреть Стили
					// SVG Библиотек -->
					<!-- SVG библиотека в телеге -->
					<ToggleButton Width="40" Height="40" ToolTip.Tip="Pencil"
								  IsChecked="{Binding IsPencilActive}"
								  Command="{Binding SelectPencilCommand}">
						<Image Source="/Assets/pencil.png"/>
					</ToggleButton>

					<ToggleButton Width="40" Height="40" ToolTip.Tip="Brush"
								  IsChecked="{Binding IsBrushActive}"
								  Command="{Binding SelectBrushCommand}">
						<Image Source="/Assets/brush.png" Width="32" Height="32"/>
					</ToggleButton>

					<ToggleButton Width="40" Height="40" ToolTip.Tip="Eraser"
								  IsChecked="{Binding IsEraserActive}"
								  Command="{Binding SelectEraserCommand}">
						<Image Source="/Assets/eraser.png" Width="32" Height="32"/>
					</ToggleButton>
				</StackPanel>
			</Border>

			<!-- Колонка 2: Фигуры -->
			<Border Grid.Column="1" BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2"
                    Padding="5"
					Background="Gray">
				<StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">

					<!-- Кнопки для фигур -->
					<Button Width="40" Height="40" ToolTip.Tip="Rectangle">
						<Rectangle Width="30" Height="20"
                                   Fill="Transparent"
                                   Stroke="Black"
                                   StrokeThickness="2"/>
					</Button>

					<Button Width="40" Height="40" ToolTip.Tip="Ellipse">
						<Ellipse Width="30" Height="20"
                                 Fill="Transparent"
                                 Stroke="Black"
                                 StrokeThickness="2"/>
					</Button>

					<Button Width="40" Height="40" ToolTip.Tip="Circle">
						<Ellipse Width="25" Height="25"
                                 Fill="Transparent"
                                 Stroke="Black"
                                 StrokeThickness="2"/>
					</Button>

					<Button Width="40" Height="40" ToolTip.Tip="Triangle">
						<Path Data="M 0,25 L 20,25 L 10,3 Z"
                              Stroke="Black"
                              Fill="Transparent"
                              StrokeThickness="2"/>
					</Button>


					<Button Width="40" Height="40" ToolTip.Tip="Line">
						<Image Source="/Assets/line.png" Width="32" Height="32"/>
					</Button>

					<Button Width="40" Height="40" ToolTip.Tip="Arrow">
						<Image Source="/Assets/arrow.png" Width="32" Height="32"/>
					</Button>
				</StackPanel>
			</Border>

			<!-- Колонка 3: Work In Progress -->
			<Border Grid.Column="2" BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="3"
                    Margin="2"
                    Padding="5"
                    Background="">
				<StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
					<TextBlock Text="🚧 Work In Progress 🚧"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="Gray"/>
				</StackPanel>
			</Border>
		</Grid>

		<!-- РАБОЧАЯ ОБЛАСТЬ (третья строка) -->
		<Border Grid.Row="2"
                BorderBrush="LightGray"
                BorderThickness="2"
                Margin="5"
                CornerRadius="3"
                Background="WhiteSmoke">

			<TextBlock Text="{Binding SelectedTool}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       FontSize="16"/>

		</Border>
	</Grid>

</Window>
